# PNW MVP v2 — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
#
# Canonical testnet endpoint (Provable Explorer v1, network-qualified):
NETWORK=testnet
ENDPOINT=https://api.explorer.provable.com/v1/testnet

# Aleo wallet credentials (operator/employer account)
ALEO_PRIVATE_KEY=
ALEO_VIEW_KEY=
ALEO_ADDRESS=

# Worker wallet addresses (public addresses only — no private keys required here)
# For MVP testnet: set via GitHub Secrets (WORKER_ADDRESS, WORKER1_ADDRESS, etc.).
# Production: portal injects these from authenticated worker sessions at runtime.
# Never commit real addresses to this file.
WORKER_ADDRESS=
WORKER1_ADDRESS=
WORKER2_ADDRESS=
WORKER3_ADDRESS=

# External program IDs
USDCX_PROGRAM_ID=test_usdcx_stablecoin.aleo

# Manifest path
MANIFEST_PATH=config/testnet.manifest.json

# PNW network selection
PNW_NETWORK=testnet
