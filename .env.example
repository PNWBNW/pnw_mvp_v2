# PNW MVP v2 — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
#
# Canonical testnet endpoint (Provable Explorer v1, network-qualified):
NETWORK=testnet
ENDPOINT=https://api.explorer.provable.com/v1/testnet

# Aleo wallet credentials (operator/employer account)
ALEO_PRIVATE_KEY=
ALEO_VIEW_KEY=
ALEO_ADDRESS=

# Worker wallet address (public address only — no private key required here)
# For MVP testnet: set to the worker's aleo1... address via GitHub secret WORKER_ADDRESS.
# Production: portal injects this from the authenticated worker session at runtime.
WORKER_ADDRESS=

# External program IDs
USDCX_PROGRAM_ID=test_usdcx_stablecoin.aleo

# Manifest path
MANIFEST_PATH=config/testnet.manifest.json

# PNW network selection
PNW_NETWORK=testnet
