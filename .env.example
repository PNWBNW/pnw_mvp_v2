# PNW MVP v2 — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
#
# Canonical testnet endpoint (Provable Explorer v1, network-qualified):
NETWORK=testnet
ENDPOINT=https://api.explorer.provable.com/v1/testnet

# Aleo wallet credentials (operator/deploy account)
ALEO_PRIVATE_KEY=
ALEO_VIEW_KEY=
ALEO_ADDRESS=

# External program IDs
USDCX_PROGRAM_ID=test_usdcx_stablecoin.aleo

# Manifest path
MANIFEST_PATH=config/testnet.manifest.json

# PNW network selection
PNW_NETWORK=testnet
